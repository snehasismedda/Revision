{
    "name": "revision-backend",
    "version": "1.0.0",
    "description": "Backend for AI-Assisted Concept Revision & Performance Tracking",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon src/index.js",
        "start": "node src/index.js",
        "migrate": "knex --knexfile src/db/knexfile.js migrate:latest",
        "migrate:rollback": "knex --knexfile src/db/knexfile.js migrate:rollback",
        "migrate:make": "knex --knexfile src/db/knexfile.js migrate:make"
    },
    "dependencies": {
        "@qdrant/js-client-rest": "^1.9.0",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.7.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "multer": "^2.0.2",
        "ollama": "^0.5.9",
        "pg": "^8.11.5",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.3"
    }
}
